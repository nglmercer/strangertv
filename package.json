{
  "name": "stranger-chat",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -k -n web,api -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "free-ports": "bash scripts/free-ports.sh",
    "dev:fresh": "bash scripts/free-ports.sh && concurrently -k -n web,api -c cyan,magenta \"vite\" \"tsx watch server/index.ts\"",
    "build": "tsc -b && vite build",
    "start": "tsx server/index.ts",
    "start:prod": "NODE_ENV=production APP_VERSION=$npm_package_version tsx server/index.ts",
    "check": "tsc -b --pretty false",
    "test": "tsx --test server/auth.test.ts server/matchmaking.test.ts server/blocks.test.ts server/config.test.ts",
    "test:integration": "tsx --test server/api.integration.test.ts",
    "test:e2e": "playwright test",
    "test:all": "npm run check && npm test && npm run test:integration && npm run build && CI=1 npm run test:e2e",
    "loadtest": "node scripts/load-test.mjs",
    "smoke": "bash scripts/smoke.sh",
    "backup": "bash scripts/backup-db.sh",
    "docker:up": "docker compose up --build -d",
    "docker:turn": "docker compose --profile turn up --build -d"
  },
  "dependencies": {
    "@hono/node-server": "^2.0.10",
    "@libsql/client": "^0.15.0",
    "concurrently": "^10.0.3",
    "hono": "^4.12.31",
    "preact": "^10.26.0",
    "tsx": "^4.19.0",
    "vite": "^8.1.4",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.51.0",
    "@preact/preset-vite": "^2.10.0",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.5.0",
    "typescript": "^7.0.2"
  },
  "overrides": {
    "@babel/core": "^7.26.10",
    "@babel/traverse": "^7.26.10",
    "@babel/types": "^7.26.10",
    "@babel/generator": "^7.26.10",
    "@babel/parser": "^7.26.10",
    "@babel/template": "^7.26.10",
    "@babel/helper-module-transforms": "^7.26.0",
    "@babel/helper-plugin-utils": "^7.26.0",
    "@babel/plugin-transform-react-jsx": "^7.25.9",
    "@babel/plugin-transform-react-jsx-development": "^7.25.9"
  }
}

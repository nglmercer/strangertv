# Example coturn config fragment for stranger video chat.
# Install coturn, set a long random static-auth-secret, open UDP/TCP 3478 and 5349.

listening-port=3478
tls-listening-port=5349
fingerprint
lt-cred-mech
use-auth-secret
static-auth-secret=REPLACE_WITH_LONG_RANDOM_SECRET
realm=turn.example.com
total-quota=100
stale-nonce=600
no-multicast-peers
no-cli

# Then in stranger .env:
# TURN_SECRET=REPLACE_WITH_LONG_RANDOM_SECRET
# TURN_URLS=turn:turn.example.com:3478,turns:turn.example.com:5349
